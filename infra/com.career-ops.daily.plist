<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.career-ops.daily</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-l</string>
        <string>-c</string>
        <string>cd $HOME/code/career-ops &amp;&amp; bin/career-ops-daily</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
        <!-- Weekdays only: 1=Monday … 5=Friday -->
        <key>Weekday</key>
        <array>
            <integer>1</integer>
            <integer>2</integer>
            <integer>3</integer>
            <integer>4</integer>
            <integer>5</integer>
        </array>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/Shared/Library/Logs/career-ops/daily.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/Shared/Library/Logs/career-ops/daily-err.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
